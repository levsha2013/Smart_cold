# --- Общее ---
# За сколько дней до истечения срока считать продукт "скоро испортится"
WARN_DAYS=3
# Час ежедневной проверки сроков (0-23, локальное время сервера)
DIGEST_HOUR=9
# Путь к файлу БД. Для локального запуска — относительный путь (создаст data/holodilnik.db рядом).
# Docker переопределяет это через environment: в docker-compose.yml, менять здесь не нужно.
DATABASE_URL=sqlite:///./data/holodilnik.db

# --- Telegram (уведомления). Если пусто — дайджест пишется в лог ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI: распознавание фото + разбор голоса (OpenRouter). Если пусто — заглушка ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_VISION_MODEL=google/gemma-4-31b-it:free
# Текстовая модель для разбора голоса в полную карточку (бесплатная по умолчанию)
OPENROUTER_TEXT_MODEL=google/gemma-4-31b-it:free

# --- AI: распознавание речи (Groq Whisper). Если пусто — заглушка ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3-turbo
