# --- Общее ---
# За сколько дней до истечения срока считать продукт "скоро испортится"
WARN_DAYS=3
# Час ежедневной проверки сроков (0-23, локальное время сервера)
DIGEST_HOUR=9
# Путь к файлу БД (внутри контейнера)
DATABASE_URL=sqlite:////data/holodilnik.db

# --- Telegram (уведомления). Если пусто — дайджест пишется в лог ---
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI: распознавание фото (OpenRouter, OpenAI-совместимый). Если пусто — заглушка ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_VISION_MODEL=qwen/qwen-2-vl-7b-instruct

# --- AI: распознавание речи (Groq Whisper). Если пусто — заглушка ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_STT_MODEL=whisper-large-v3-turbo
